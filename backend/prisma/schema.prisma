// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  caseId        String   @unique
  phone         String   @unique
  email         String?
  fullName      String
  dateOfBirth   DateTime
  gender        String
  address       Json
  role          String   @default("patient")
  language      String   @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  profile       PatientProfile?
  documents     Document[]
  appointments  Appointment[]
  applications  FundingApplication[]
  activities    Activity[]
  messages      Message[]
}

model PatientProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Medical Info
  status            String
  cancerType        String?
  stage             String?
  diagnosisDate     DateTime?
  hospital          String?
  
  // Financial Info
  annualIncome      String
  hasPMJAY          Boolean
  pmjayCardNumber   String?
  hasInsurance      Boolean
  insuranceProvider String?
  
  // Emergency Contact
  emergencyContact  Json
  
  // Consent
  consents          Json
  
  // Case Manager
  caseManagerId     String?
  caseManager       CaseManager? @relation(fields: [caseManagerId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CaseManager {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String
  photo           String?
  availableHours  String
  specialization  String?
  
  // Relations
  patients        PatientProfile[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Document {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  type        String
  category    String
  fileUrl     String
  fileSize    Int
  mimeType    String
  
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  doctor      String
  hospital    String
  type        String   // in-person, online
  date        DateTime
  time        String
  status      String   @default("upcoming")
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TreatmentCost {
  id                String   @id @default(uuid())
  userId            String
  
  hospitalName      String
  estimateAmount    Float
  itemizedBreakdown Json
  validUntil        DateTime
  status            String   @default("pending")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model FundingApplication {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  source          String   // pmjay, ngo, nbfc, csr, crowdfunding, insurance
  amount          Float
  status          String   @default("pending")
  applicationData Json
  
  approvedAmount  Float?
  approvedAt      DateTime?
  disbursedAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Activity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String
  title       String
  description String
  metadata    Json?
  
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  senderId    String
  senderType  String   // patient, case-manager, system
  content     String
  read        Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

model NGOPartner {
  id              String   @id @default(uuid())
  name            String
  description     String?
  eligibilityCriteria Json
  maxGrantAmount  Float
  contactEmail    String
  contactPhone    String
  status          String   @default("active")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Hospital {
  id              String   @id @default(uuid())
  name            String
  address         String
  city            String
  state           String
  pinCode         String
  phone           String
  email           String?
  specializations String[]
  pmjayEmpanelled Boolean  @default(false)
  latitude        Float?
  longitude       Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
